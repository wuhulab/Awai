{
  "model": [
    {
      "name": "DeepSeek模型映射",
      "priority": 10,
      "actions": {
        "url": "https://ai-api.shunx.top",
        "key": "默认密钥",
        "mappings": {
          "DeepSeek-R1-Qwen-14B": "DeepSeek-R1-Distill-Qwen-14B",
          "DeepSeek-V3.2": "DeepSeek-V3.2-Exp"
        }
      },
      "exposure": "true"
    }
  ],
  "auto": [
    {
      "name": "DeepSeek-auto",
      "actions": {
        "quotation": {
          "deepseek-V3": 1,
          "deepseek-V3.2": 2
        },
        "rules": "priority"
      },
      "enable": "true"
    }
  ]
}
